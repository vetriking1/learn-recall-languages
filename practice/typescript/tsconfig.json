{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "lib": ["ES2022"],
    "typeRoots": ["../../typescript/node_modules/@types"],
    "types": ["node"]
  },
  "ts-node": {
    "transpileOnly": false
  },
  "include": ["*.ts"]
}
